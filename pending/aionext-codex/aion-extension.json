{
    "$schema": "https://raw.githubusercontent.com/iOfficeAI/AionHub/spec/v0/extension-manifest.schema.json",
    "author": "Aionui Official",
    "contributes": {
        "acpAdapters": [
            {
                "id": "codex",
                "name": "Codex",
                "description": "Official OpenAI Codex adapter (via ACP adapter)",
                "connectionType": "stdio",
                "cliCommand": "codex",
                "defaultCliPath": "bunx @zed-industries/codex-acp@0.9.5",
                "authRequired": true,
                "supportsStreaming": false
            }
        ]
    },
    "description": "Integrates OpenAI Codex CLI as an ACP adapter in AionUi.",
    "displayName": "Codex",
    "engine": {
        "aionui": "^1.0.0"
    },
    "lifecycle": {
        "onInstall": {
            "shell": {
                "cliCommand": "bun",
                "args": [
                    "run",
                    "scripts/install.ts"
                ]
            },
            "timeout": 120000
        }
    },
    "name": "aionext-codex",
    "version": "1.0.0"
}
