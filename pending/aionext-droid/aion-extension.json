{
    "$schema": "https://raw.githubusercontent.com/iOfficeAI/AionHub/spec/v0/extension-manifest.schema.json",
    "author": "Aionui Official",
    "contributes": {
        "acpAdapters": [
            {
                "id": "droid",
                "name": "Droid",
                "description": "Official Factory Droid adapter",
                "connectionType": "stdio",
                "cliCommand": "droid",
                "defaultCliPath": "bunx droid",
                "authRequired": true,
                "supportsStreaming": false,
                "acpArgs": [
                    "exec",
                    "--output-format",
                    "acp"
                ]
            }
        ]
    },
    "description": "Integrates Factory Droid as an ACP adapter in AionUi.",
    "displayName": "Droid",
    "engine": {
        "aionui": "^1.0.0"
    },
    "lifecycle": {
        "onInstall": {
            "shell": {
                "cliCommand": "bun",
                "args": [
                    "add",
                    "-g",
                    "--trust",
                    "droid"
                ]
            },
            "timeout": 60000
        }
    },
    "name": "aionext-droid",
    "version": "1.0.0"
}
