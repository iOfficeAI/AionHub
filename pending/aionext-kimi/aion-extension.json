{
    "$schema": "https://raw.githubusercontent.com/iOfficeAI/AionHub/spec/v0/extension-manifest.schema.json",
    "author": "Aionui Official",
    "contributes": {
        "acpAdapters": [
            {
                "id": "kimi",
                "name": "Kimi Code",
                "description": "Official Kimi Code adapter",
                "connectionType": "stdio",
                "cliCommand": "kimi",
                "authRequired": true,
                "supportsStreaming": false,
                "acpArgs": [
                    "acp"
                ]
            }
        ]
    },
    "description": "Integrates Kimi Code CLI as an ACP adapter in AionUi.",
    "displayName": "Kimi Code",
    "engine": {
        "aionui": "^1.0.0"
    },
    "lifecycle": {
        "onInstall": {
            "shell": {
                "cliCommand": "bun",
                "args": [
                    "run",
                    "scripts/install.ts"
                ]
            },
            "timeout": 120000
        }
    },
    "name": "aionext-kimi",
    "version": "1.0.0"
}
