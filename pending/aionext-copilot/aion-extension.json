{
    "$schema": "https://raw.githubusercontent.com/iOfficeAI/AionHub/spec/v0/extension-manifest.schema.json",
    "author": "Aionui Official",
    "contributes": {
        "acpAdapters": [
            {
                "id": "copilot",
                "name": "GitHub Copilot",
                "description": "Official GitHub Copilot adapter",
                "connectionType": "stdio",
                "cliCommand": "copilot",
                "defaultCliPath": "bunx @github/copilot",
                "acpArgs": ["--acp"],
                "authRequired": true,
                "supportsStreaming": false
            }
        ]
    },
    "description": "Integrates GitHub Copilot as an ACP adapter in AionUi.",
    "displayName": "GitHub Copilot",
    "engine": {
        "aionui": "^1.0.0"
    },
    "lifecycle": {
        "onInstall": {
            "shell": {
                "cliCommand": "bun",
                "args": ["install", "-g", "@github/copilot"]
            },
            "timeout": 60000
        }
    },
    "name": "aionext-copilot",
    "version": "1.0.0"
}
