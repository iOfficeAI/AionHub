{
    "author": "Aionui Official",
    "contributes": {
        "acpAdapters": [
            {
                "id": "copilot",
                "name": "GitHub Copilot",
                "description": "Official GitHub Copilot adapter",
                "connectionType": "stdio",
                "cliCommand": "copilot",
                "defaultCliPath": "bunx @githubnext/github-copilot-cli",
                "authRequired": false,
                "enabled": true,
                "supportsStreaming": false,
                "acpArgs": [
                    "--acp",
                    "--stdio"
                ]
            }
        ]
    },
    "description": "Integrates GitHub Copilot as an ACP adapter in AionUi.",
    "displayName": "GitHub Copilot",
    "engine": {
        "aionui": "^1.0.0"
    },
    "lifecycle": {
        "onInstall": {
            "shell": {
                "cliCommand": "bun",
                "args": [
                    "add",
                    "-g",
                    "@githubnext/github-copilot-cli"
                ]
            },
            "timeout": 30000
        }
    },
    "name": "aionext-copilot",
    "version": "1.0.0"
}
