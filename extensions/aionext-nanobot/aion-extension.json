{
    "$schema": "https://raw.githubusercontent.com/iOfficeAI/AionHub/spec/v0/extension-manifest.schema.json",
    "author": "Aionui Official",
    "contributes": {
        "acpAdapters": [
            {
                "id": "nanobot",
                "name": "Nano Bot",
                "description": "Official Nano Bot adapter",
                "connectionType": "stdio",
                "cliCommand": "nanobot",
                "defaultCliPath": "bunx nanobot",
                "authRequired": false,
                "supportsStreaming": false
            }
        ]
    },
    "description": "Integrates Nano Bot as an ACP adapter in AionUi.",
    "displayName": "Nano Bot",
    "engine": {
        "aionui": "^1.0.0"
    },
    "lifecycle": {
        "onInstall": {
            "shell": {
                "cliCommand": "bun",
                "args": [
                    "add",
                    "-g",
                    "nanobot"
                ]
            },
            "timeout": 30000
        }
    },
    "name": "aionext-nanobot",
    "version": "1.0.0"
}
