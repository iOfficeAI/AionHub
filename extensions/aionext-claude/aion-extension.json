{
    "$schema": "https://raw.githubusercontent.com/iOfficeAI/AionHub/spec/v0/extension-manifest.schema.json",
    "author": "Aionui Official",
    "contributes": {
        "acpAdapters": [
            {
                "id": "claude",
                "name": "Claude Code",
                "description": "Official Claude Code adapter",
                "connectionType": "stdio",
                "cliCommand": "claude",
                "defaultCliPath": "bunx @anthropic-ai/claude-code",
                "authRequired": true,
                "supportsStreaming": false
            }
        ]
    },
    "description": "Integrates Anthropic's Claude Code CLI as an ACP adapter in AionUi.",
    "displayName": "Claude Code",
    "engine": {
        "aionui": "^1.0.0"
    },
    "lifecycle": {
        "onInstall": {
            "shell": {
                "cliCommand": "bun",
                "args": [
                    "add",
                    "-g",
                    "@anthropic-ai/claude-code"
                ]
            },
            "timeout": 30000
        }
    },
    "name": "aionext-claude",
    "version": "1.0.0"
}
