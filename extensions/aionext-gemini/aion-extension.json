{
    "$schema": "https://raw.githubusercontent.com/iOfficeAI/AionHub/spec/v1/extension-manifest.schema.json",
    "author": "Aionui Official",
    "contributes": {
        "acpAdapters": [
            {
                "id": "gemini",
                "name": "Google CLI",
                "description": "Official Google CLI adapter",
                "connectionType": "stdio",
                "cliCommand": "gemini",
                "defaultCliPath": "bunx @google/gemini-cli",
                "authRequired": true,
                "supportsStreaming": true
            }
        ]
    },
    "description": "Integrates Google CLI as an ACP adapter in AionUi.",
    "displayName": "Google CLI",
    "engine": {
        "aionui": "^1.0.0"
    },
    "lifecycle": {
        "onInstall": {
            "shell": {
                "cliCommand": "bun",
                "args": [
                    "add",
                    "-g",
                    "@google/gemini-cli"
                ]
            },
            "timeout": 30000
        }
    },
    "name": "aionext-gemini",
    "version": "1.0.0"
}
