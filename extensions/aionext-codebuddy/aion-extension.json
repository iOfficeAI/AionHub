{
    "$schema": "https://raw.githubusercontent.com/iOfficeAI/AionHub/spec/v0/extension-manifest.schema.json",
    "author": "Aionui Official",
    "contributes": {
        "acpAdapters": [
            {
                "id": "codebuddy",
                "name": "CodeBuddy",
                "description": "Official CodeBuddy adapter",
                "connectionType": "stdio",
                "cliCommand": "codebuddy",
                "defaultCliPath": "bunx @tencent-ai/codebuddy-code",
                "authRequired": true,
                "supportsStreaming": false,
                "acpArgs": [
                    "--acp"
                ]
            }
        ]
    },
    "description": "Integrates CodeBuddy as an ACP adapter in AionUi.",
    "displayName": "CodeBuddy",
    "engine": {
        "aionui": "^1.0.0"
    },
    "lifecycle": {
        "onInstall": {
            "shell": {
                "cliCommand": "bun",
                "args": [
                    "add",
                    "-g",
                    "@tencent-ai/codebuddy-code"
                ]
            },
            "timeout": 30000
        }
    },
    "name": "aionext-codebuddy",
    "version": "1.0.0"
}
