{
    "$schema": "https://raw.githubusercontent.com/iOfficeAI/AionHub/spec/v0/extension-manifest.schema.json",
    "author": "Aionui Official",
    "contributes": {
        "acpAdapters": [
            {
                "id": "goose",
                "name": "Goose",
                "description": "Official Goose adapter",
                "connectionType": "stdio",
                "cliCommand": "goose",
                "defaultCliPath": "bunx goose-cli",
                "authRequired": false,
                "supportsStreaming": false,
                "acpArgs": [
                    "acp"
                ]
            }
        ]
    },
    "description": "Integrates Goose as an ACP adapter in AionUi.",
    "displayName": "Goose",
    "engine": {
        "aionui": "^1.0.0"
    },
    "lifecycle": {
        "onInstall": {
            "shell": {
                "cliCommand": "bun",
                "args": [
                    "add",
                    "-g",
                    "goose-cli"
                ]
            },
            "timeout": 30000
        }
    },
    "name": "aionext-goose",
    "version": "1.0.0"
}
