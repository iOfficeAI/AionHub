{
    "$schema": "https://raw.githubusercontent.com/iOfficeAI/AionHub/spec/v0/extension-manifest.schema.json",
    "author": "Aionui Official",
    "contributes": {
        "acpAdapters": [
            {
                "id": "qoder",
                "name": "Qoder CLI",
                "description": "Official Qoder CLI adapter",
                "connectionType": "stdio",
                "cliCommand": "qodercli",
                "defaultCliPath": "bunx @qoder-ai/qodercli",
                "authRequired": true,
                "supportsStreaming": false,
                "acpArgs": [
                    "--acp"
                ]
            }
        ]
    },
    "description": "Integrates Qoder CLI as an ACP adapter in AionUi.",
    "displayName": "Qoder CLI",
    "engine": {
        "aionui": "^1.0.0"
    },
    "lifecycle": {
        "onInstall": {
            "shell": {
                "cliCommand": "bun",
                "args": [
                    "add",
                    "-g",
                    "--trust",
                    "@qoder-ai/qodercli"
                ]
            },
            "timeout": 60000
        }
    },
    "name": "aionext-qoder",
    "version": "1.0.0"
}
