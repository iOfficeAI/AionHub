{
    "author": "Aionui Official",
    "contributes": {
        "acpAdapters": [
            {
                "id": "iflow",
                "name": "iFlow CLI",
                "description": "Official iFlow CLI adapter",
                "connectionType": "stdio",
                "cliCommand": "iflow",
                "defaultCliPath": "bunx @iflow-ai/iflow-cli",
                "authRequired": true,
                "enabled": true,
                "supportsStreaming": false,
                "skillsDirs": [
                    ".iflow/skills"
                ]
            }
        ]
    },
    "description": "Integrates iFlow CLI as an ACP adapter in AionUi.",
    "displayName": "iFlow CLI",
    "engine": {
        "aionui": "^1.0.0"
    },
    "lifecycle": {
        "onInstall": {
            "shell": {
                "cliCommand": "bun",
                "args": [
                    "add",
                    "-g",
                    "@iflow-ai/iflow-cli"
                ]
            },
            "timeout": 30000
        }
    },
    "name": "aionext-iflow",
    "version": "1.0.0"
}
