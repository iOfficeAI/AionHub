{
    "$schema": "https://raw.githubusercontent.com/iOfficeAI/AionHub/spec/v1/extension-manifest.schema.json",
    "author": "Aionui Official",
    "contributes": {
        "acpAdapters": [
            {
                "id": "openclaw-gateway",
                "name": "OpenClaw",
                "description": "Official OpenClaw adapter",
                "connectionType": "stdio",
                "cliCommand": "openclaw",
                "defaultCliPath": "bunx openclaw",
                "authRequired": false,
                "supportsStreaming": true,
                "acpArgs": [
                    "gateway"
                ]
            }
        ]
    },
    "description": "Integrates OpenClaw as an ACP adapter in AionUi.",
    "displayName": "OpenClaw",
    "engine": {
        "aionui": "^1.0.0"
    },
    "lifecycle": {
        "onInstall": {
            "shell": {
                "cliCommand": "bun",
                "args": [
                    "add",
                    "-g",
                    "openclaw"
                ]
            },
            "timeout": 30000
        }
    },
    "name": "aionext-openclaw-gateway",
    "version": "1.0.0"
}
