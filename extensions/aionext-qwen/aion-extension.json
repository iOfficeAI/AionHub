{
    "$schema": "https://raw.githubusercontent.com/iOfficeAI/AionHub/spec/v1/extension-manifest.schema.json",
    "author": "Aionui Official",
    "contributes": {
        "acpAdapters": [
            {
                "id": "qwen",
                "name": "Qwen Code",
                "description": "Official Qwen Code adapter",
                "connectionType": "stdio",
                "cliCommand": "qwen",
                "defaultCliPath": "bunx @qwen-code/qwen-code",
                "authRequired": true,
                "supportsStreaming": true,
                "acpArgs": [
                    "--acp"
                ]
            }
        ]
    },
    "description": "Integrates Qwen CLI as an ACP adapter in AionUi.",
    "displayName": "Qwen Code",
    "engine": {
        "aionui": "^1.0.0"
    },
    "lifecycle": {
        "onInstall": {
            "shell": {
                "cliCommand": "bun",
                "args": [
                    "add",
                    "-g",
                    "@qwen-code/qwen-code"
                ]
            },
            "timeout": 30000
        }
    },
    "name": "aionext-qwen",
    "version": "1.0.0"
}
