{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/iOfficeAI/AionHub/spec/v0/extension-manifest.schema.json",
  "version": "0.1.0",
  "title": "ExtensionManifest",
  "description": "AionUI Extension Manifest schema. Note: Zod .refine() validations (e.g. duplicate ID checks, conditional required fields) cannot be expressed in JSON Schema and are enforced at runtime only.",
  "type": "object",
  "required": ["name", "displayName", "version", "contributes"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$",
      "minLength": 2,
      "maxLength": 64,
      "description": "Extension name in kebab-case. Cannot start with reserved prefixes: aion-, internal-, builtin-, system-"
    },
    "displayName": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+(-[\\w.]+)?$",
      "description": "Semver format (e.g. 1.0.0)"
    },
    "description": { "type": "string" },
    "author": { "type": "string" },
    "icon": { "type": "string" },
    "homepage": { "type": "string", "format": "uri" },
    "apiVersion": {
      "type": "string",
      "pattern": "^\\^?\\d+\\.\\d+\\.\\d+(-[\\w.]+)?$",
      "description": "Extension API compatibility range (e.g. ^1.0.0)"
    },
    "dependencies": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "pattern": "^\\^?\\d+\\.\\d+\\.\\d+(-[\\w.]+)?$"
      },
      "description": "Extension dependencies: { extensionName: versionRange }"
    },
    "engine": {
      "type": "object",
      "properties": {
        "aionui": {
          "type": "string",
          "pattern": "^\\^?\\d+\\.\\d+\\.\\d+(-[\\w.]+)?$",
          "description": "Compatible AionUI core version range"
        }
      },
      "additionalProperties": false
    },
    "i18n": {
      "type": "object",
      "properties": {
        "localesDir": { "type": "string", "default": "i18n" },
        "defaultLocale": { "type": "string", "default": "en-US" }
      },
      "additionalProperties": false
    },
    "lifecycle": {
      "type": "object",
      "properties": {
        "onInstall": { "$ref": "#/$defs/LifecycleHook" },
        "onActivate": { "$ref": "#/$defs/LifecycleHook" },
        "onDeactivate": { "$ref": "#/$defs/LifecycleHook" },
        "onUninstall": { "$ref": "#/$defs/LifecycleHook" }
      },
      "additionalProperties": false
    },
    "permissions": {
      "type": "object",
      "properties": {
        "storage": { "type": "boolean", "default": false },
        "network": {
          "oneOf": [
            { "type": "boolean" },
            {
              "type": "object",
              "required": ["allowedDomains"],
              "properties": {
                "allowedDomains": {
                  "type": "array",
                  "items": { "type": "string" },
                  "minItems": 1
                },
                "reasoning": { "type": "string" }
              },
              "additionalProperties": false
            }
          ],
          "default": false
        },
        "shell": { "type": "boolean", "default": false },
        "filesystem": {
          "type": "string",
          "enum": ["extension-only", "workspace", "full"],
          "default": "extension-only"
        },
        "clipboard": { "type": "boolean", "default": false },
        "activeUser": { "type": "boolean", "default": false },
        "events": { "type": "boolean", "default": true }
      },
      "additionalProperties": false
    },
    "contributes": { "$ref": "#/$defs/Contributes" }
  },
  "$defs": {
    "LifecycleHook": {
      "description": "A lifecycle hook — either a script path string, or an object with script/shell. Runtime constraint: either 'script' or 'shell' must be provided.",
      "oneOf": [
        { "type": "string" },
        {
          "type": "object",
          "properties": {
            "timeout": { "type": "integer", "exclusiveMinimum": 0 },
            "script": { "type": "string" },
            "shell": {
              "type": "object",
              "required": ["cliCommand"],
              "properties": {
                "cliCommand": { "type": "string" },
                "args": { "type": "array", "items": { "type": "string" } }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "Field": {
      "type": "object",
      "required": ["key", "label", "type"],
      "properties": {
        "key": { "type": "string" },
        "label": { "type": "string" },
        "type": {
          "type": "string",
          "enum": ["text", "password", "select", "number", "boolean"]
        },
        "required": { "type": "boolean" },
        "options": { "type": "array", "items": { "type": "string" } },
        "default": {
          "oneOf": [
            { "type": "string" },
            { "type": "number" },
            { "type": "boolean" }
          ]
        }
      },
      "additionalProperties": false
    },
    "AcpAdapter": {
      "type": "object",
      "required": ["id", "name"],
      "description": "Runtime constraint: CLI/stdio adapters require cliCommand or defaultCliPath; websocket/http adapters require endpoint.",
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "cliCommand": { "type": "string" },
        "defaultCliPath": { "type": "string" },
        "acpArgs": { "type": "array", "items": { "type": "string" } },
        "env": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "icon": { "type": "string" },
        "authRequired": { "type": "boolean" },
        "supportsStreaming": { "type": "boolean" },
        "connectionType": {
          "type": "string",
          "enum": ["cli", "stdio", "websocket", "http"],
          "default": "cli"
        },
        "endpoint": { "type": "string" },
        "models": { "type": "array", "items": { "type": "string" } },
        "apiKeyFields": {
          "type": "array",
          "items": { "$ref": "#/$defs/Field" },
          "description": "API Key fields for Settings UI. Values are injected into adapter env when spawning."
        },
        "yoloMode": {
          "type": "object",
          "required": ["type"],
          "properties": {
            "type": { "type": "string", "enum": ["session", "global"] },
            "sessionMode": { "type": "string" }
          },
          "additionalProperties": false
        },
        "healthCheck": {
          "type": "object",
          "required": ["versionCommand"],
          "properties": {
            "versionCommand": { "type": "string" },
            "timeout": { "type": "number" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "McpTransport": {
      "oneOf": [
        {
          "type": "object",
          "required": ["type", "command"],
          "properties": {
            "type": { "const": "stdio" },
            "command": { "type": "string" },
            "args": { "type": "array", "items": { "type": "string" } },
            "env": {
              "type": "object",
              "additionalProperties": { "type": "string" }
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["type", "url"],
          "properties": {
            "type": { "const": "sse" },
            "url": { "type": "string" },
            "headers": {
              "type": "object",
              "additionalProperties": { "type": "string" }
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["type", "url"],
          "properties": {
            "type": { "const": "http" },
            "url": { "type": "string" },
            "headers": {
              "type": "object",
              "additionalProperties": { "type": "string" }
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["type", "url"],
          "properties": {
            "type": { "const": "streamable_http" },
            "url": { "type": "string" },
            "headers": {
              "type": "object",
              "additionalProperties": { "type": "string" }
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "McpServer": {
      "type": "object",
      "required": ["name", "transport"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "transport": { "$ref": "#/$defs/McpTransport" },
        "enabled": { "type": "boolean", "default": true }
      },
      "additionalProperties": false
    },
    "Assistant": {
      "type": "object",
      "required": ["id", "name", "presetAgentType", "contextFile"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "avatar": { "type": "string" },
        "presetAgentType": {
          "type": "string",
          "minLength": 1,
          "description": "Built-in types: gemini, claude, codex, codebuddy, opencode — or any extension-contributed adapter ID"
        },
        "contextFile": { "type": "string", "minLength": 1 },
        "models": { "type": "array", "items": { "type": "string" } },
        "enabledSkills": { "type": "array", "items": { "type": "string" } },
        "prompts": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "Skill": {
      "type": "object",
      "required": ["name", "file"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "file": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "ChannelPlugin": {
      "type": "object",
      "required": ["type", "name", "entryPoint"],
      "properties": {
        "type": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "icon": { "type": "string" },
        "entryPoint": { "type": "string", "minLength": 1 },
        "credentialFields": {
          "type": "array",
          "items": { "$ref": "#/$defs/Field" }
        },
        "configFields": {
          "type": "array",
          "items": { "$ref": "#/$defs/Field" }
        }
      },
      "additionalProperties": false
    },
    "ApiRoute": {
      "type": "object",
      "required": ["path", "entryPoint"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "entryPoint": { "type": "string" },
        "description": { "type": "string" },
        "auth": { "type": "boolean", "default": true }
      },
      "additionalProperties": false
    },
    "WsHandler": {
      "type": "object",
      "required": ["namespace", "entryPoint"],
      "properties": {
        "namespace": { "type": "string" },
        "entryPoint": { "type": "string" },
        "description": { "type": "string" }
      },
      "additionalProperties": false
    },
    "Middleware": {
      "type": "object",
      "required": ["entryPoint"],
      "properties": {
        "entryPoint": { "type": "string" },
        "description": { "type": "string" },
        "applyTo": { "type": "string", "default": "/**" },
        "order": {
          "type": "string",
          "enum": ["before", "after"],
          "default": "before"
        }
      },
      "additionalProperties": false
    },
    "StaticAsset": {
      "type": "object",
      "required": ["urlPrefix", "directory"],
      "properties": {
        "urlPrefix": { "type": "string", "minLength": 1 },
        "directory": { "type": "string" },
        "description": { "type": "string" }
      },
      "additionalProperties": false
    },
    "Webui": {
      "type": "object",
      "properties": {
        "apiRoutes": {
          "type": "array",
          "items": { "$ref": "#/$defs/ApiRoute" }
        },
        "wsHandlers": {
          "type": "array",
          "items": { "$ref": "#/$defs/WsHandler" }
        },
        "middleware": {
          "type": "array",
          "items": { "$ref": "#/$defs/Middleware" }
        },
        "staticAssets": {
          "type": "array",
          "items": { "$ref": "#/$defs/StaticAsset" }
        }
      },
      "additionalProperties": false
    },
    "Theme": {
      "type": "object",
      "required": ["id", "name", "file"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "file": { "type": "string" },
        "cover": { "type": "string" }
      },
      "additionalProperties": false
    },
    "ModelProvider": {
      "type": "object",
      "required": ["id", "platform", "name"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "platform": {
          "type": "string",
          "minLength": 1,
          "description": "e.g. custom, gemini, anthropic, new-api, bedrock"
        },
        "name": { "type": "string", "minLength": 1 },
        "baseUrl": { "type": "string" },
        "models": { "type": "array", "items": { "type": "string" } },
        "logo": { "type": "string" }
      },
      "additionalProperties": false
    },
    "SettingsTab": {
      "type": "object",
      "required": ["id", "name", "entryPoint"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "icon": { "type": "string" },
        "entryPoint": { "type": "string", "minLength": 1 },
        "position": {
          "type": "object",
          "required": ["anchor", "placement"],
          "properties": {
            "anchor": { "type": "string", "minLength": 1 },
            "placement": {
              "type": "string",
              "enum": ["before", "after"]
            }
          },
          "additionalProperties": false,
          "description": "Built-in tab IDs for anchor: gemini, model, agent, tools, display, webui, system, about"
        },
        "order": {
          "type": "number",
          "default": 100,
          "description": "Fallback numeric order when multiple tabs target the same anchor+placement. Lower = first."
        }
      },
      "additionalProperties": false
    },
    "Contributes": {
      "type": "object",
      "description": "Runtime constraint: IDs within each array must be unique; agent IDs must not collide with assistant IDs.",
      "properties": {
        "acpAdapters": {
          "type": "array",
          "items": { "$ref": "#/$defs/AcpAdapter" }
        },
        "mcpServers": {
          "type": "array",
          "items": { "$ref": "#/$defs/McpServer" }
        },
        "assistants": {
          "type": "array",
          "items": { "$ref": "#/$defs/Assistant" }
        },
        "agents": {
          "type": "array",
          "items": { "$ref": "#/$defs/Assistant" },
          "description": "Agent presets — structurally identical to assistants but semantically represent autonomous agents"
        },
        "skills": {
          "type": "array",
          "items": { "$ref": "#/$defs/Skill" }
        },
        "channelPlugins": {
          "type": "array",
          "items": { "$ref": "#/$defs/ChannelPlugin" }
        },
        "webui": { "$ref": "#/$defs/Webui" },
        "themes": {
          "type": "array",
          "items": { "$ref": "#/$defs/Theme" }
        },
        "settingsTabs": {
          "type": "array",
          "items": { "$ref": "#/$defs/SettingsTab" }
        },
        "modelProviders": {
          "type": "array",
          "items": { "$ref": "#/$defs/ModelProvider" }
        }
      },
      "additionalProperties": false
    }
  }
}
